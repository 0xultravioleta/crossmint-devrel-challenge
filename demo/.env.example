# Crossmint server API key
# Create one at https://www.crossmint.com/console
# Required scopes:
#   wallets.create
#   wallets.read
#   wallets:transactions.create
#   wallets:transactions.sign
#   wallets:balance.read
CROSSMINT_API_KEY=

# Email used as the Crossmint wallet owner identifier
# Any email works - does not need to be a real inbox
WALLET_OWNER_EMAIL=demo@example.com

# Chain for the Crossmint wallet
# Stick with solana-devnet for the quickstart - no real money needed
WALLET_CHAIN=solana-devnet

# x402 facilitator endpoint
# Default: Faremeter (Crossmint's preferred facilitator)
# Alternative: https://facilitator.ultravioletadao.xyz (Ultravioleta DAO, 19 mainnets)
X402_FACILITATOR_URL=https://facilitator.corbits.dev

# Paywalled endpoint this demo calls
# Default points to the "weather" paywall from crossmint-agentic-finance
# You can also run the included server.ts locally - see README
PAYWALL_ENDPOINT=https://weather.crossmint-agentic-finance.example/weather
